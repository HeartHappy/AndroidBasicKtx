<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBannerHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Infinite Carousel Demo"
            android:textColor="@android:color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBannerDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="ViewPager2 + AbsSpecialAdapter with duplicate edge items and seamless reset."
            android:textColor="@android:color/darker_gray"
            android:textSize="14sp" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vpBanner"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tvBannerIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            tools:text="1 / 5" />

        <TextView
            android:id="@+id/tvBannerTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Auto scroll runs every 3 seconds. Tap a banner to verify the real position mapping."
            android:textColor="@android:color/darker_gray"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnExample1"
            style="@style/style_button"
            android:layout_width="match_parent"
            android:layout_marginTop="24dp"
            android:text="Example1" />

        <Button
            android:id="@+id/btnExample2"
            style="@style/style_button"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:text="Example2" />

    </LinearLayout>
</ScrollView>
